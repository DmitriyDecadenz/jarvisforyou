# OpenAI (required for AI chat and Whisper STT)
OPENAI_API_KEY=sk-your-key-here

# Model settings
OPENAI_CHAT_MODEL=gpt-4o-mini
OPENAI_WHISPER_MODEL=whisper-1
OPENAI_TTS_MODEL=tts-1
OPENAI_TTS_VOICE=onyx

# Optional: Ollama local AI (offline chat)
OLLAMA_ENABLED=false
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2

# Voice
JARVIS_TTS_ENGINE=macos
# macos | openai
JARVIS_MACOS_VOICE=Daniel
JARVIS_WAKE_WORDS=jarvis,hey jarvis

# Security
JARVIS_CONFIRM_DESTRUCTIVE=true

# Startup
JARVIS_LAUNCH_AT_LOGIN=false
JARVIS_START_LISTENING=true
